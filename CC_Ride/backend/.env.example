# =============================================================================
# CC Ride — Backend Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
# =============================================================================

# Database (PostgreSQL on Contabo VPS)
DATABASE_URL="postgresql://ccride:CHANGE_ME@localhost:5432/ccride?schema=public"

# JWT
JWT_SECRET="CHANGE_ME_use_a_long_random_string"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL="https://app.ccride.ng"
ADMIN_URL="https://admin.ccride.ng"

# Paystack (https://dashboard.paystack.com)
PAYSTACK_PUBLIC_KEY="pk_live_XXXXXXXX"
PAYSTACK_SECRET_KEY="sk_live_XXXXXXXX"
PAYSTACK_WEBHOOK_SECRET="XXXXXXXX"

# Flutterwave (https://dashboard.flutterwave.com)
FLUTTERWAVE_PUBLIC_KEY="FLWPUBK-XXXXXXXX"
FLUTTERWAVE_SECRET_KEY="FLWSECK-XXXXXXXX"
FLUTTERWAVE_ENC_KEY="XXXXXXXX"
FLUTTERWAVE_WEBHOOK_SECRET="XXXXXXXX"

# Firebase (for FCM push notifications)
FIREBASE_PROJECT_ID="ccride-XXXXX"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@ccride-XXXXX.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXX\n-----END PRIVATE KEY-----"

# Google Maps
GOOGLE_MAPS_KEY="AIzaXXXXXXXXXX"

# Termii SMS (Nigerian SMS provider — termii.com)
TERMII_API_KEY="XXXXXXXX"
TERMII_SENDER_ID="CC Ride"

# SMTP (use Brevo/SendGrid for production)
SMTP_HOST="smtp.brevo.com"
SMTP_PORT=587
SMTP_USER="XXXXXXXX"
SMTP_PASS="XXXXXXXX"
SMTP_FROM="noreply@ccride.ng"

# File storage (Cloudflare R2 or local for dev)
STORAGE_PROVIDER="local"           # local | r2
R2_ACCOUNT_ID="XXXXXXXX"
R2_ACCESS_KEY_ID="XXXXXXXX"
R2_SECRET_ACCESS_KEY="XXXXXXXX"
R2_BUCKET_NAME="ccride-assets"
R2_PUBLIC_URL="https://assets.ccride.ng"
