// =============================================================================
// CC Ride — Prisma Schema
// Database : PostgreSQL 15+
// ORM      : Prisma 5.x
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "views"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, pgcrypto]
}

// =============================================================================
// ENUMS
// =============================================================================

enum RideStatus {
  pending
  driver_assigned
  driver_en_route
  in_progress
  completed
  cancelled

  @@map("ride_status")
}

enum BookingStatus {
  pending
  confirmed
  processing
  in_progress
  completed
  cancelled
  no_show

  @@map("booking_status")
}

enum BookingMethod {
  instant
  scheduled

  @@map("booking_method")
}

enum UserStatus {
  active
  suspended
  pending_verification
  banned

  @@map("user_status")
}

enum DriverStatus {
  pending
  active
  suspended
  offline
  on_trip
  rejected

  @@map("driver_status")
}

enum VehicleStatus {
  pending
  approved
  rejected
  inactive

  @@map("vehicle_status")
}

enum DocumentStatus {
  pending
  approved
  rejected
  expired

  @@map("document_status")
}

// Payout statuses — 'paid' is an alias kept for legacy controller compatibility
enum PayoutStatus {
  pending
  processing
  paid        // alias for completed; retained for controller compatibility
  completed
  failed
  reversed

  @@map("payout_status")
}

enum PayoutMethod {
  paystack
  flutterwave
  bank_transfer

  @@map("payout_method")
}

enum PaymentGateway {
  paystack
  flutterwave
  company_account  // corporate rides charged to company budget

  @@map("payment_gateway")
}

enum PaymentStatus {
  pending
  successful
  failed
  reversed
  refunded

  @@map("payment_status")
}

enum RideScheduleType {
  one_time
  recurring_daily
  recurring_weekly

  @@map("ride_schedule_type")
}

enum ApprovalAction {
  pending
  approved
  rejected
  escalated

  @@map("approval_action")
}

enum BudgetPeriodType {
  monthly
  quarterly
  annual

  @@map("budget_period_type")
}

enum CompanyStatus {
  active
  suspended
  pending_approval
  inactive
  rejected          // company application rejected by super-admin

  @@map("company_status")
}

enum EmployeeRole {
  employee
  manager
  company_admin
  company_finance
  company_hr

  @@map("employee_role")
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed

  @@map("ticket_status")
}

enum TicketPriority {
  low
  medium
  high
  urgent

  @@map("ticket_priority")
}

enum NotificationType {
  booking_confirmed
  driver_assigned
  driver_arrived
  ride_started
  ride_completed
  payment_processed
  approval_required
  approval_decided
  budget_alert
  general

  @@map("notification_type")
}

// =============================================================================
// PLATFORM ADMINISTRATION
// =============================================================================

/// Super-admin accounts that access the operations panel.
/// Referenced by controllers as `prisma.adminUser`.
model AdminUser {
  id           BigInt    @id @default(autoincrement())
  username     String    @unique
  email        String    @unique
  passwordHash String    @map("password_hash")
  isSuperAdmin Boolean   @default(false) @map("is_super_admin")
  isActive     Boolean   @default(true)  @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt      @map("updated_at")

  // Relations
  reviewedDocuments  DriverDocument[]
  assignedTickets    SupportTicket[]
  onboardedCompanies Company[]
  generatedInvoices  Invoice[]

  @@map("admin_users")
}

/// Global platform configuration — always a single row (id = 1).
model PlatformSettings {
  id   Int @id @default(1)

  // Branding
  appName    String  @default("CC Ride") @map("app_name")
  appLogoUrl String? @map("app_logo_url")

  // Localisation
  timezone       String @default("Africa/Lagos")
  currency       String @default("NGN")
  currencySymbol String @default("₦") @map("currency_symbol")

  // Finance
  platformCommission    Decimal @default(15.00) @db.Decimal(5, 2)  @map("platform_commission")
  bookingFee            Decimal @default(100.00) @db.Decimal(15, 2) @map("booking_fee")
  minPayoutAmount       Decimal @default(5000.00) @db.Decimal(15, 2) @map("min_payout_amount")
  driverPayoutThreshold Decimal @default(5000.00) @db.Decimal(15, 2) @map("driver_payout_threshold")
  referralBonus         Decimal @default(500.00) @db.Decimal(15, 2)  @map("referral_bonus")
  signupBonus           Decimal @default(0.00) @db.Decimal(15, 2)    @map("signup_bonus")

  // Ride rules
  maxCancellationMinutes Int     @default(5)   @map("max_cancellation_minutes")
  surgeMultiplierMax     Decimal @default(2.5) @db.Decimal(5, 2) @map("surge_multiplier_max")

  // App mode
  maintenanceMode Boolean @default(false) @map("maintenance_mode")

  // Support contact
  supportEmail String? @map("support_email")
  supportPhone String? @map("support_phone")

  // Paystack
  paystackPublicKey  String? @map("paystack_public_key")
  paystackSecretKey  String? @map("paystack_secret_key")

  // Flutterwave
  flutterwavePublicKey String? @map("flutterwave_public_key")
  flutterwaveSecretKey String? @map("flutterwave_secret_key")
  flutterwaveEncKey    String? @map("flutterwave_enc_key")

  // Google Maps (key stored masked for settings page display)
  googleMapsKey       String? @map("google_maps_key")
  googleMapsKeyMasked String? @map("google_maps_key_masked")

  // Firebase / Push
  fcmServerKey    String? @map("fcm_server_key")
  firebaseProjectId String? @map("firebase_project_id")

  // OneSignal (alternative push)
  onesignalAppId       String? @map("onesignal_app_id")
  onesignalAppIdMasked String? @map("onesignal_app_id_masked")
  onesignalApiKey      String? @map("onesignal_api_key")

  // SMTP
  smtpHost      String? @map("smtp_host")
  smtpPort      Int?    @map("smtp_port")
  smtpUsername  String? @map("smtp_username")
  smtpPassword  String? @map("smtp_password")
  smtpFromEmail String? @map("smtp_from_email")

  // SMS (Termii / Africa's Talking)
  smsApiKey   String? @map("sms_api_key")
  smsSenderId String? @map("sms_sender_id")

  // App store links
  iosAppUrl     String? @map("ios_app_url")
  androidAppUrl String? @map("android_app_url")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

model ApiRateLimit {
  id            BigInt    @id @default(autoincrement())
  identifier    String
  endpoint      String
  attempts      Int       @default(1)
  lastAttemptAt DateTime  @default(now()) @map("last_attempt_at")
  blockedUntil  DateTime? @map("blocked_until")

  @@unique([identifier, endpoint])
  @@map("api_rate_limits")
}

// =============================================================================
// USERS & DRIVER PROFILES
// =============================================================================

model User {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  email            String?    @unique
  mobile           String
  countryCode      String     @default("+234") @map("country_code")
  passwordHash     String     @map("password_hash")
  profilePicUrl    String?    @map("profile_pic_url")
  dateOfBirth      DateTime?  @db.Date @map("date_of_birth")
  bio              String?
  walletBalance    Decimal    @default(0.00) @db.Decimal(15, 2) @map("wallet_balance")
  isMobileVerified Boolean    @default(false) @map("is_mobile_verified")
  isEmailVerified  Boolean    @default(false) @map("is_email_verified")
  isDriver         Boolean    @default(false) @map("is_driver")
  status           UserStatus @default(pending_verification)
  referralCode     String?    @unique @map("referral_code")
  referredById     String?    @db.Uuid @map("referred_by")
  fcmToken         String?    @map("fcm_token")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt      @map("updated_at")
  lastActiveAt     DateTime?  @map("last_active_at")

  // Self-referential
  referredBy    User?  @relation("UserReferrals", fields: [referredById], references: [id])
  referredUsers User[] @relation("UserReferrals")

  // Driver
  driverProfile DriverProfile?
  ridesAsDriver Ride[]  @relation("RideDriver")
  vehicles      Vehicle[]
  bankAccounts   DriverBankAccount[]
  payoutRequests PayoutRequest[]

  // Passenger
  bookings      Booking[]      @relation("BookingPassenger")
  bookingsAsDriver Booking[]   @relation("BookingDriver")
  rideRequests  RideRequest[]

  // Finance
  walletTransactions WalletTransaction[]
  couponRedemptions  CouponRedemption[]

  // Ratings
  driverRatingsGiven    DriverRating[] @relation("RatingPassenger")
  driverRatingsReceived DriverRating[] @relation("RatingDriver")

  // Other
  notifications Notification[]
  supportTickets SupportTicket[]

  // Corporate
  companyMemberships CompanyEmployee[]
  createdBudgets     Budget[]           @relation("BudgetCreator")
  createdPolicies    RidePolicy[]       @relation("PolicyCreator")

  approvalWorkflowsAsApprover   ApprovalWorkflow[] @relation("WorkflowApprover")
  approvalWorkflowsAsEscalation ApprovalWorkflow[] @relation("WorkflowEscalation")
  approvalRequestsMade          ApprovalRequest[]  @relation("ApprovalRequester")
  approvalRequestsToDecide      ApprovalRequest[]  @relation("ApprovalDecider")
  approvalRequestsEscalatedTo   ApprovalRequest[]  @relation("ApprovalEscalation")

  receiptsAsEmployee RideReceipt[]

  @@unique([mobile, countryCode])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("users")
}

model DriverProfile {
  userId        String       @id @db.Uuid @map("user_id")
  licenseNumber String       @map("license_number")
  licenseExpiry DateTime     @db.Date @map("license_expiry")
  nin           String?
  bvn           String?
  status        DriverStatus @default(pending)
  averageRating Decimal      @default(0.00) @db.Decimal(3, 2) @map("average_rating")
  totalTrips    Int          @default(0)    @map("total_trips")
  totalEarnings Decimal      @default(0.00) @db.Decimal(15, 2) @map("total_earnings")

  // Current location (updated via Socket.IO)
  currentLocationLat Decimal? @db.Decimal(10, 7) @map("current_location_lat")
  currentLocationLng Decimal? @db.Decimal(10, 7) @map("current_location_lng")
  lastLocationAt     DateTime? @map("last_location_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents DriverDocument[]

  @@map("driver_profiles")
}

model DriverDocument {
  id            BigInt         @id @default(autoincrement())
  driverId      String         @db.Uuid @map("driver_id")
  documentType  String         @map("document_type")
  fileUrl       String         @map("file_url")
  status        DocumentStatus @default(pending)
  rejectionNote String?        @map("rejection_note")
  expiresAt     DateTime?      @db.Date @map("expires_at")
  reviewedById  BigInt?        @map("reviewed_by")
  reviewedAt    DateTime?      @map("reviewed_at")
  createdAt     DateTime       @default(now()) @map("created_at")

  // Relations
  driver     DriverProfile  @relation(fields: [driverId], references: [userId], onDelete: Cascade)
  reviewedBy AdminUser?     @relation(fields: [reviewedById], references: [id])

  @@map("driver_documents")
}

/// Driver bank accounts — separate model so a driver can have multiple accounts
/// and payouts can include { bankAccount { bankName, accountNumber } }.
model DriverBankAccount {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  driverId              String    @db.Uuid @map("driver_id")
  bankName              String    @map("bank_name")
  bankCode              String?   @map("bank_code")   // e.g. '058' for GTBank — required for Flutterwave transfers
  accountNumber         String    @map("account_number")
  accountName           String    @map("account_name")
  paystackRecipientCode String?   @map("paystack_recipient_code")
  isPrimary             Boolean   @default(true) @map("is_primary")
  createdAt             DateTime  @default(now()) @map("created_at")

  driver   User            @relation(fields: [driverId], references: [id], onDelete: Cascade)
  payouts  PayoutRequest[]

  @@unique([driverId, accountNumber])
  @@map("driver_bank_accounts")
}

// =============================================================================
// VEHICLES
// =============================================================================

model VehicleType {
  id     BigInt  @id @default(autoincrement())
  title  String  @unique
  status Boolean @default(true)

  vehicles    Vehicle[]
  policies    RidePolicy[]

  @@map("vehicle_types")
}

model VehicleModel {
  id     BigInt  @id @default(autoincrement())
  title  String  @unique
  status Boolean @default(true)

  vehicles Vehicle[]

  @@map("vehicle_models")
}

model VehicleColor {
  id     BigInt  @id @default(autoincrement())
  title  String  @unique
  status Boolean @default(true)

  vehicles Vehicle[]

  @@map("vehicle_colors")
}

model Vehicle {
  id           BigInt        @id @default(autoincrement())
  driverId     String        @db.Uuid @map("driver_id")
  modelId      BigInt        @map("model_id")
  typeId       BigInt        @map("type_id")
  colorId      BigInt        @map("color_id")
  year         Int           @db.SmallInt
  licensePlate String        @unique @map("license_plate")
  photoUrl     String?       @map("photo_url")
  seatCapacity Int           @default(4) @db.SmallInt @map("seat_capacity")
  status       VehicleStatus @default(pending)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt      @map("updated_at")

  // Relations
  driver User         @relation(fields: [driverId], references: [id], onDelete: Cascade)
  model  VehicleModel @relation(fields: [modelId],  references: [id])
  type   VehicleType  @relation(fields: [typeId], references: [id])
  color  VehicleColor @relation(fields: [colorId], references: [id])
  rides  Ride[]

  @@map("vehicles")
}

// =============================================================================
// RIDES & BOOKINGS
// =============================================================================

model Ride {
  id                   String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  driverId             String           @db.Uuid @map("driver_id")
  vehicleId            BigInt?          @map("vehicle_id")

  // Route
  originAddress      String  @map("origin_address")
  originLat          Decimal @db.Decimal(10, 7) @map("origin_lat")
  originLng          Decimal @db.Decimal(10, 7) @map("origin_lng")
  destinationAddress String  @map("destination_address")
  destinationLat     Decimal @db.Decimal(10, 7) @map("destination_lat")
  destinationLng     Decimal @db.Decimal(10, 7) @map("destination_lng")

  // Schedule
  scheduleType RideScheduleType @default(one_time) @map("schedule_type")
  scheduledAt  DateTime         @map("scheduled_at")

  // Pricing (NGN)
  baseFare            Decimal  @db.Decimal(15, 2) @map("base_fare")
  farePerKm           Decimal? @db.Decimal(15, 2) @map("fare_per_km")
  estimatedDistanceKm Decimal? @db.Decimal(8, 2)  @map("estimated_distance_km")
  estimatedDurationMin Int?    @map("estimated_duration_min")

  // Capacity & preferences
  availableSeats Int      @db.SmallInt @map("available_seats")
  luggageAllowed String   @default("M") @map("luggage_allowed")
  restrictions   String[] @default([])
  tripNotes      String?  @map("trip_notes")

  // Status & OTPs
  status     RideStatus @default(pending)
  pickupOtp  String     @map("pickup_otp")
  dropoffOtp String     @map("dropoff_otp")

  // Timestamps
  startedAt          DateTime? @map("started_at")
  completedAt        DateTime? @map("completed_at")
  cancelledAt        DateTime? @map("cancelled_at")
  cancellationReason String?   @map("cancellation_reason")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt      @map("updated_at")

  // Relations
  driver  User     @relation("RideDriver", fields: [driverId], references: [id])
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
  stops    RideStop[]
  tracking RideTracking[]
  bookings Booking[]

  @@index([driverId])
  @@index([status])
  @@index([scheduledAt])
  @@map("rides")
}

model RideStop {
  id        BigInt  @id @default(autoincrement())
  rideId    String  @db.Uuid @map("ride_id")
  stopOrder Int     @db.SmallInt @map("stop_order")
  address   String
  lat       Decimal @db.Decimal(10, 7)
  lng       Decimal @db.Decimal(10, 7)

  ride Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)

  @@map("ride_stops")
}

model RideTracking {
  id         BigInt   @id @default(autoincrement())
  rideId     String   @db.Uuid @map("ride_id")
  driverId   String   @db.Uuid @map("driver_id")
  lat        Decimal  @db.Decimal(10, 7)
  lng        Decimal  @db.Decimal(10, 7)
  speedKmh   Decimal? @db.Decimal(6, 2) @map("speed_kmh")
  recordedAt DateTime @default(now()) @map("recorded_at")

  ride Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)

  @@index([rideId, recordedAt(sort: Desc)])
  @@map("ride_tracking")
}

model Booking {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rideId      String  @db.Uuid @map("ride_id")
  passengerId String  @db.Uuid @map("passenger_id")
  // Denormalised driver FK — mirrors ride.driverId for direct queries
  driverId    String? @db.Uuid @map("driver_id")

  // Corporate (nullable — personal bookings leave these null)
  companyId         String? @db.Uuid @map("company_id")
  departmentId      BigInt? @map("department_id")
  costCentreId      BigInt? @map("cost_centre_id")
  // Denorm FK — set after approval request is created; no Prisma relation to avoid circular dep
  approvalRequestId BigInt? @map("approval_request_id")

  // Seats
  seatsBooked Int @default(1) @db.SmallInt @map("seats_booked")

  // Fares (NGN)
  subtotal           Decimal @db.Decimal(15, 2)
  couponDiscount     Decimal @default(0.00) @db.Decimal(15, 2) @map("coupon_discount")
  walletAmountUsed   Decimal @default(0.00) @db.Decimal(15, 2) @map("wallet_amount_used")
  totalAmount        Decimal @db.Decimal(15, 2) @map("total_amount")
  driverEarning      Decimal @db.Decimal(15, 2) @map("driver_earning")
  platformCommission Decimal @db.Decimal(15, 2) @map("platform_commission")
  bookingFee         Decimal @default(0.00) @db.Decimal(15, 2) @map("booking_fee")

  // Payment
  paymentGateway   PaymentGateway? @map("payment_gateway")
  paymentReference String?         @unique @map("payment_reference")
  paymentStatus    PaymentStatus   @default(pending) @map("payment_status")

  // Method & rating
  bookingMethod    BookingMethod @default(instant) @map("booking_method")
  passengerRating  Int?          @db.SmallInt @map("passenger_rating")
  passengerReview  String?       @map("passenger_review")

  // Status
  status BookingStatus @default(pending)

  // Timestamps
  startedAt          DateTime? @map("started_at")
  confirmedAt        DateTime? @map("confirmed_at")
  completedAt        DateTime? @map("completed_at")
  cancelledAt        DateTime? @map("cancelled_at")
  cancellationReason String?   @map("cancellation_reason")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt      @map("updated_at")

  // Relations
  ride            Ride              @relation(fields: [rideId], references: [id])
  passenger       User              @relation("BookingPassenger", fields: [passengerId], references: [id])
  driver          User?             @relation("BookingDriver", fields: [driverId], references: [id])
  company         Company?          @relation(fields: [companyId], references: [id])
  department      Department?       @relation(fields: [departmentId], references: [id])
  costCentre       CostCentre?       @relation(fields: [costCentreId], references: [id])
  approvalRequests ApprovalRequest[] // back-relation: find via prisma.approvalRequest.findFirst({ where: { bookingId } })
  receipt          RideReceipt?
  driverRating       DriverRating?
  budgetTransactions BudgetTransaction[]
  couponRedemption   CouponRedemption?
  walletTransactions WalletTransaction[]
  supportTickets     SupportTicket[]

  @@index([passengerId])
  @@index([driverId])
  @@index([rideId])
  @@index([companyId])
  @@index([departmentId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("bookings")
}

model RideRequest {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  passengerId        String   @db.Uuid @map("passenger_id")
  originAddress      String   @map("origin_address")
  originLat          Decimal  @db.Decimal(10, 7) @map("origin_lat")
  originLng          Decimal  @db.Decimal(10, 7) @map("origin_lng")
  destinationAddress String   @map("destination_address")
  destinationLat     Decimal  @db.Decimal(10, 7) @map("destination_lat")
  destinationLng     Decimal  @db.Decimal(10, 7) @map("destination_lng")
  departureDate      DateTime @db.Date @map("departure_date")
  seatsRequired      Int      @default(1) @db.SmallInt @map("seats_required")
  notes              String?
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")

  passenger User @relation(fields: [passengerId], references: [id])

  @@index([isActive, departureDate])
  @@map("ride_requests")
}

// =============================================================================
// PAYMENTS & WALLET
// =============================================================================

model WalletTransaction {
  id           BigInt   @id @default(autoincrement())
  userId       String   @db.Uuid @map("user_id")
  bookingId    String?  @db.Uuid @map("booking_id")
  amount       Decimal  @db.Decimal(15, 2)  // positive = credit, negative = debit
  balanceAfter Decimal  @db.Decimal(15, 2) @map("balance_after")
  description  String
  reference    String?  @unique
  createdAt    DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([bookingId])
  @@map("wallet_transactions")
}

/// Driver payout requests — referenced as `prisma.payoutRequest` in controllers.
model PayoutRequest {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  driverId         String       @db.Uuid @map("driver_id")
  bankAccountId    String?      @db.Uuid @map("bank_account_id")
  amount           Decimal      @db.Decimal(15, 2)
  method           PayoutMethod @default(paystack)
  status           PayoutStatus @default(pending)
  gatewayReference String?      @unique @map("gateway_reference")
  failureReason    String?      @map("failure_reason")
  requestedAt      DateTime     @default(now()) @map("requested_at")
  processedAt      DateTime?    @map("processed_at")
  completedAt      DateTime?    @map("completed_at")

  driver      User               @relation(fields: [driverId], references: [id])
  bankAccount DriverBankAccount? @relation(fields: [bankAccountId], references: [id])

  @@map("payout_requests")
}

// =============================================================================
// COUPONS & PROMOTIONS
// =============================================================================

model Coupon {
  id            BigInt   @id @default(autoincrement())
  imageUrl      String?  @map("image_url")
  title         String
  code          String   @unique
  subtitle      String?
  description   String?
  expiresAt     DateTime @map("expires_at")
  minAmount     Decimal  @default(0.00) @db.Decimal(15, 2) @map("min_amount")
  discountValue Decimal  @db.Decimal(15, 2) @map("discount_value")
  isPercentage  Boolean  @default(false) @map("is_percentage")
  maxUses       Int?     @map("max_uses")
  usesCount     Int      @default(0) @map("uses_count")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  redemptions CouponRedemption[]

  @@map("coupons")
}

model CouponRedemption {
  id         BigInt   @id @default(autoincrement())
  couponId   BigInt   @map("coupon_id")
  userId     String   @db.Uuid @map("user_id")
  bookingId  String?  @unique @db.Uuid @map("booking_id")   // one redemption per booking
  redeemedAt DateTime @default(now()) @map("redeemed_at")

  coupon  Coupon   @relation(fields: [couponId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@unique([couponId, userId])
  @@map("coupon_redemptions")
}

// =============================================================================
// RATINGS
// =============================================================================

model DriverRating {
  id          BigInt   @id @default(autoincrement())
  bookingId   String   @unique @db.Uuid @map("booking_id")
  driverId    String   @db.Uuid @map("driver_id")
  passengerId String   @db.Uuid @map("passenger_id")
  rating      Int      @db.SmallInt
  review      String?
  createdAt   DateTime @default(now()) @map("created_at")

  booking   Booking @relation(fields: [bookingId], references: [id])
  driver    User    @relation("RatingDriver", fields: [driverId], references: [id])
  passenger User    @relation("RatingPassenger", fields: [passengerId], references: [id])

  @@map("driver_ratings")
}

// =============================================================================
// SUPPORT
// =============================================================================

model SupportTicket {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String         @db.Uuid @map("user_id")
  bookingId   String?        @db.Uuid @map("booking_id")
  subject     String
  description String
  category    String?        // e.g. "payment", "driver", "app", "general"
  status      TicketStatus   @default(open)
  priority    TicketPriority @default(medium)
  assignedTo  BigInt?        @map("assigned_to")
  resolvedAt  DateTime?      @map("resolved_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt      @map("updated_at")

  user     User           @relation(fields: [userId], references: [id])
  booking  Booking?       @relation(fields: [bookingId], references: [id])
  assignee AdminUser?     @relation(fields: [assignedTo], references: [id])
  messages SupportMessage[]

  @@index([status, priority])
  @@map("support_tickets")
}

model SupportMessage {
  id         BigInt   @id @default(autoincrement())
  ticketId   String   @db.Uuid @map("ticket_id")
  // Flexible sender: user, admin, or system
  senderType String   @default("user") @map("sender_type")  // 'user' | 'admin' | 'system'
  senderId   String?  @map("sender_id")                     // userId or adminId as string
  body       String
  createdAt  DateTime @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("support_messages")
}

// =============================================================================
// NOTIFICATIONS
// =============================================================================

model Notification {
  id     BigInt           @id @default(autoincrement())
  userId String           @db.Uuid @map("user_id")
  type   NotificationType
  title  String
  body   String
  data   Json?
  isRead Boolean          @default(false) @map("is_read")
  sentAt DateTime         @default(now()) @map("sent_at")
  readAt DateTime?        @map("read_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// =============================================================================
// CONTENT MANAGEMENT
// =============================================================================

model Faq {
  id        BigInt   @id @default(autoincrement())
  question  String
  answer    String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("faqs")
}

model ContentPage {
  id        BigInt   @id @default(autoincrement())
  slug      String   @unique
  title     String
  content   String
  isActive  Boolean  @default(true) @map("is_active")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("content_pages")
}

// =============================================================================
// CORPORATE LAYER
// =============================================================================

model Company {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  registrationNumber String?       @unique @map("registration_number")
  taxId              String?       @map("tax_id")
  industry           String?
  logoUrl            String?       @map("logo_url")
  address            String?
  city               String?
  state              String        @default("Lagos")
  contactName        String        @map("contact_name")
  contactEmail       String        @unique @map("contact_email")
  contactPhone       String?       @map("contact_phone")  // optional — some companies register without phone
  status             CompanyStatus @default(pending_approval)
  // Subscription
  monthlySubscription   Decimal  @default(50000.00) @db.Decimal(15, 2) @map("monthly_subscription")
  subscriptionActive    Boolean  @default(false) @map("subscription_active")
  subscriptionExpiresAt DateTime? @map("subscription_expires_at")
  // Commission override (null = use platform default)
  commissionRate     Decimal?  @db.Decimal(5, 2) @map("commission_rate")
  // Meta
  onboardedById BigInt?   @map("onboarded_by")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt      @map("updated_at")

  // Relations
  onboardedBy       AdminUser?         @relation(fields: [onboardedById], references: [id])
  departments       Department[]
  costCentres       CostCentre[]
  employees         CompanyEmployee[]
  bookings          Booking[]
  budgets           Budget[]
  approvalWorkflows ApprovalWorkflow[]
  ridePolicies      RidePolicy[]
  invoices          Invoice[]
  receipts          RideReceipt[]

  @@map("companies")
}

model Department {
  id        BigInt   @id @default(autoincrement())
  companyId String   @db.Uuid @map("company_id")
  name      String
  code      String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  company           Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  costCentres       CostCentre[]
  employees         CompanyEmployee[]
  bookings          Booking[]
  budgets           Budget[]
  approvalWorkflows ApprovalWorkflow[]
  ridePolicies      RidePolicy[]
  receipts          RideReceipt[]

  @@unique([companyId, name])
  @@map("departments")
}

model CostCentre {
  id           BigInt   @id @default(autoincrement())
  companyId    String   @db.Uuid @map("company_id")
  departmentId BigInt?  @map("department_id")
  name         String
  code         String
  description  String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id])
  employees  CompanyEmployee[]
  bookings   Booking[]
  budgets    Budget[]
  receipts   RideReceipt[]

  @@unique([companyId, code])
  @@map("cost_centres")
}

model CompanyEmployee {
  id                BigInt       @id @default(autoincrement())
  companyId         String       @db.Uuid @map("company_id")
  userId            String       @db.Uuid @map("user_id")
  departmentId      BigInt?      @map("department_id")
  costCentreId      BigInt?      @map("cost_centre_id")
  role              EmployeeRole @default(employee)
  employeeNumber    String?      @map("employee_number")
  jobTitle          String?      @map("job_title")
  monthlySpendLimit Decimal?     @db.Decimal(15, 2) @map("monthly_spend_limit")
  isActive          Boolean      @default(true) @map("is_active")
  invitedAt         DateTime     @default(now()) @map("invited_at")
  joinedAt          DateTime?    @map("joined_at")
  deactivatedAt     DateTime?    @map("deactivated_at")

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id])
  costCentre CostCentre? @relation(fields: [costCentreId], references: [id])

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
  @@map("company_employees")
}

// =============================================================================
// BUDGETS
// =============================================================================

model Budget {
  id              BigInt           @id @default(autoincrement())
  companyId       String           @db.Uuid @map("company_id")
  departmentId    BigInt?          @map("department_id")
  costCentreId    BigInt?          @map("cost_centre_id")
  periodType      BudgetPeriodType @default(monthly) @map("period_type")
  periodStart     DateTime         @db.Date @map("period_start")
  periodEnd       DateTime         @db.Date @map("period_end")
  allocatedAmount Decimal          @db.Decimal(15, 2) @map("allocated_amount")
  alertThreshold  Decimal          @default(80.00) @db.Decimal(5, 2) @map("alert_threshold")
  isActive        Boolean          @default(true) @map("is_active")
  createdById     String           @db.Uuid @map("created_by")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt      @map("updated_at")

  company      Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department   Department?         @relation(fields: [departmentId], references: [id])
  costCentre   CostCentre?         @relation(fields: [costCentreId], references: [id])
  createdBy    User                @relation("BudgetCreator", fields: [createdById], references: [id])
  transactions BudgetTransaction[]

  @@index([companyId, periodStart, periodEnd])
  @@map("budgets")
}

model BudgetTransaction {
  id           BigInt   @id @default(autoincrement())
  budgetId     BigInt   @map("budget_id")
  bookingId    String?  @db.Uuid @map("booking_id")
  employeeId   String?  @db.Uuid @map("employee_id")
  amount       Decimal  @db.Decimal(15, 2)
  description  String
  transactedAt DateTime @default(now()) @map("transacted_at")

  budget  Budget   @relation(fields: [budgetId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@map("budget_transactions")
}

// =============================================================================
// APPROVAL WORKFLOWS
// =============================================================================

model ApprovalWorkflow {
  id                   BigInt       @id @default(autoincrement())
  companyId            String       @db.Uuid @map("company_id")
  departmentId         BigInt?      @map("department_id")
  name                 String
  requiresApproval     Boolean      @default(true) @map("requires_approval")
  autoApproveBelow     Decimal?     @db.Decimal(15, 2) @map("auto_approve_below")
  approverRole         EmployeeRole @default(manager) @map("approver_role")
  specificApproverId   String?      @db.Uuid @map("specific_approver_id")
  escalationHours      Int          @default(2) @map("escalation_hours")
  escalationApproverId String?      @db.Uuid @map("escalation_approver_id")
  isActive             Boolean      @default(true) @map("is_active")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt      @map("updated_at")

  company            Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department         Department?       @relation(fields: [departmentId], references: [id])
  specificApprover   User?             @relation("WorkflowApprover", fields: [specificApproverId], references: [id])
  escalationApprover User?             @relation("WorkflowEscalation", fields: [escalationApproverId], references: [id])
  requests           ApprovalRequest[]

  @@map("approval_workflows")
}

model ApprovalRequest {
  id                 BigInt         @id @default(autoincrement())
  workflowId         BigInt         @map("workflow_id")
  bookingId          String         @db.Uuid @map("booking_id")
  requesterId        String         @db.Uuid @map("requester_id")
  approverId         String?        @db.Uuid @map("approver_id")
  // Snapshot for approver display
  originAddress      String         @map("origin_address")
  destinationAddress String         @map("destination_address")
  estimatedFare      Decimal        @db.Decimal(15, 2) @map("estimated_fare")
  scheduledAt        DateTime       @map("scheduled_at")
  // Decision
  status             ApprovalAction @default(pending)
  decisionNote       String?        @map("decision_note")
  decidedAt          DateTime?      @map("decided_at")
  // Escalation
  escalatedAt   DateTime? @map("escalated_at")
  escalatedToId String?   @db.Uuid @map("escalated_to")
  // Expiry
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  workflow  ApprovalWorkflow @relation(fields: [workflowId], references: [id])
  booking   Booking          @relation(fields: [bookingId], references: [id])
  requester User             @relation("ApprovalRequester", fields: [requesterId], references: [id])
  approver    User?            @relation("ApprovalDecider", fields: [approverId], references: [id])
  escalatedTo User?            @relation("ApprovalEscalation", fields: [escalatedToId], references: [id])

  @@index([approverId, status])
  @@index([bookingId])
  @@map("approval_requests")
}

// =============================================================================
// RIDE POLICIES
// =============================================================================

model RidePolicy {
  id                   BigInt   @id @default(autoincrement())
  companyId            String   @db.Uuid @map("company_id")
  departmentId         BigInt?  @map("department_id")
  name                 String
  allowedDays          Int[]    @map("allowed_days")          // 1=Mon…7=Sun; empty = all days
  allowedTimeFrom      String?  @map("allowed_time_from")     // "HH:MM" in Africa/Lagos
  allowedTimeTo        String?  @map("allowed_time_to")
  allowedVehicleTypeIds Int[]   @map("allowed_vehicle_types") // empty = any type
  maxVehicleTypeId     BigInt?  @map("max_vehicle_type_id")
  maxFarePerTrip       Decimal? @db.Decimal(15, 2) @map("max_fare_per_trip")
  maxMonthlySpend      Decimal? @db.Decimal(15, 2) @map("max_monthly_spend")
  advanceBookingMinutes Int?    @map("advance_booking_minutes")
  extraRules           Json     @default("{}") @map("extra_rules")
  isActive             Boolean  @default(true) @map("is_active")
  createdById          String   @db.Uuid @map("created_by")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt      @map("updated_at")

  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department     Department?  @relation(fields: [departmentId], references: [id])
  createdBy      User         @relation("PolicyCreator", fields: [createdById], references: [id])
  maxVehicleType VehicleType? @relation(fields: [maxVehicleTypeId], references: [id])

  @@map("ride_policies")
}

// =============================================================================
// INVOICES & RECEIPTS
// =============================================================================

model RideReceipt {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId          String          @unique @db.Uuid @map("booking_id")
  companyId          String?         @db.Uuid @map("company_id")
  employeeId         String          @db.Uuid @map("employee_id")
  departmentId       BigInt?         @map("department_id")
  costCentreId       BigInt?         @map("cost_centre_id")
  // Amounts (NGN)
  baseFare           Decimal         @db.Decimal(15, 2) @map("base_fare")
  platformFee        Decimal         @db.Decimal(15, 2) @map("platform_fee")
  discount           Decimal         @default(0.00) @db.Decimal(15, 2)
  totalCharged       Decimal         @db.Decimal(15, 2) @map("total_charged")
  // Trip
  originAddress      String          @map("origin_address")
  destinationAddress String          @map("destination_address")
  distanceKm         Decimal?        @db.Decimal(8, 2) @map("distance_km")
  durationMinutes    Int?            @map("duration_minutes")
  rideStartedAt      DateTime?       @map("ride_started_at")
  rideCompletedAt    DateTime?       @map("ride_completed_at")
  // Payment
  paymentReference   String?         @map("payment_reference")
  paymentGateway     PaymentGateway? @map("payment_gateway")
  // Receipt number (auto-generated by DB trigger or application layer)
  receiptNumber      String          @unique @map("receipt_number")
  pdfUrl             String?         @map("pdf_url")
  issuedAt           DateTime        @default(now()) @map("issued_at")

  booking      Booking          @relation(fields: [bookingId], references: [id])
  company      Company?         @relation(fields: [companyId], references: [id])
  employee     User             @relation(fields: [employeeId], references: [id])
  department   Department?      @relation(fields: [departmentId], references: [id])
  costCentre   CostCentre?      @relation(fields: [costCentreId], references: [id])
  invoiceItems InvoiceLineItem[]

  @@index([companyId])
  @@map("ride_receipts")
}

model Invoice {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId        String   @db.Uuid @map("company_id")
  invoiceNumber    String   @unique @map("invoice_number")
  periodStart      DateTime @db.Date @map("period_start")
  periodEnd        DateTime @db.Date @map("period_end")
  // Amounts (NGN)
  subtotal         Decimal  @db.Decimal(15, 2)
  vatRate          Decimal  @default(7.50) @db.Decimal(5, 2) @map("vat_rate")
  vatAmount        Decimal  @db.Decimal(15, 2) @map("vat_amount")
  totalAmount      Decimal  @db.Decimal(15, 2) @map("total_amount")
  // Status
  isPaid           Boolean  @default(false) @map("is_paid")
  paidAt           DateTime? @map("paid_at")
  paymentReference String?  @map("payment_reference")
  dueDate          DateTime @db.Date @map("due_date")
  pdfUrl           String?  @map("pdf_url")
  notes            String?
  generatedById    BigInt?  @map("generated_by")
  createdAt        DateTime @default(now()) @map("created_at")

  company     Company          @relation(fields: [companyId], references: [id])
  generatedBy AdminUser?       @relation(fields: [generatedById], references: [id])
  lineItems   InvoiceLineItem[]

  @@index([companyId, periodStart])
  @@map("invoices")
}

model InvoiceLineItem {
  id             BigInt    @id @default(autoincrement())
  invoiceId      String    @db.Uuid @map("invoice_id")
  receiptId      String?   @db.Uuid @map("receipt_id")
  description    String
  departmentName String?   @map("department_name")
  costCentre     String?   @map("cost_centre")
  employeeName   String?   @map("employee_name")
  quantity       Int       @default(1)
  unitPrice      Decimal   @db.Decimal(15, 2) @map("unit_price")
  totalPrice     Decimal   @db.Decimal(15, 2) @map("total_price")
  rideDate       DateTime? @db.Date @map("ride_date")

  invoice Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  receipt RideReceipt? @relation(fields: [receiptId], references: [id])

  @@map("invoice_line_items")
}
